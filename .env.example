# Copy this file to .env and fill in real values. .env is gitignored — it is
# never committed, so your real credentials never land in git history.

# Camouflage domain used only on first start, when the client identity is
# generated. Must be a globally trusted, unblocked, high-traffic domain your
# local ISP lets you reach freely. Defaults to swcdn.apple.com if unset.
# Other options: aspnetcdn.com, www.apple.com, www.microsoft.com
SNI_DOMAIN=swcdn.apple.com

# Optional. Point a real domain's DNS A/AAAA record at this server to get an
# automatically issued and renewed Let's Encrypt certificate for the portal —
# requires port 80 to be reachable from the internet (forward it on your
# router if you're behind NAT). Leave blank to keep using the self-signed
# certificate that's generated automatically on first start.
DOMAIN=

# Required before the portal will serve any connection details (UUID, REALITY
# keys, VLESS link) — until both are set, every portal route returns a 500.
# Pick real credentials; don't use the placeholders below.
PORTAL_USER_NAME=admin
PORTAL_PASSWORD=changeme

# External port the portal is published on. Only used so the portal can print its own
# URL at startup — change this only if you also change the "16810:8080" port mapping
# for the portal service in docker-compose.yaml.
PORTAL_PORT=16810
